# ABOUTME: Builds the cloud-ide image: VS Code (code-server) + Continue + LiteLLM + MCP
# ABOUTME: LiteLLM proxies OpenAI so Continue needs no API key configuration.

FROM codercom/code-server:latest

# Install Node.js 20 LTS, pip, and supervisord
USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates gettext-base python3-pip supervisor \
  && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
  && apt-get install -y --no-install-recommends nodejs \
  && rm -rf /var/lib/apt/lists/*

# Install LiteLLM proxy
RUN pip3 install --no-cache-dir --break-system-packages 'litellm[proxy]'

# Inject Cisco TLS inspection CA into certifi's bundle so LiteLLM can reach external APIs
COPY config/cisco-ca.crt /tmp/cisco-ca.crt
RUN cat /tmp/cisco-ca.crt >> $(python3 -m certifi) && rm /tmp/cisco-ca.crt

# Install Continue extension from Open VSX
RUN code-server --install-extension Continue.continue

# Copy code-server config and runtime configs
# code-server runs as root (upstream entrypoint behaviour), so configs go under /root
RUN mkdir -p /root/.config/code-server /root/config
COPY config/code-server.yaml /root/.config/code-server/config.yaml
COPY config/continue-config.yaml /root/config/continue-config.yaml
COPY config/litellm-config.yaml /root/config/litellm-config.yaml
COPY config/supervisord.conf /root/config/supervisord.conf

# Set our entrypoint
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
